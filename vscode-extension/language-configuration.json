{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "`", "close": "`", "notIn": ["string", "comment"] },
    { "open": "/*", "close": "*/", "notIn": ["string"] },
    { "open": "/**", "close": " */", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "`", "close": "`" }
  ],
  "colorizedBracketPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(state|view|style|actions|props|router|store|routes|getters)\\s*\\{|^\\s*@(?:if|else-if|for|each|else).*\\{\\s*$|^\\s*/\\*\\*|^\\s*@(?:media|supports|container|keyframes|layer)\\b",
      "end": "^\\s*\\}|^\\s*\\*/"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^.*\\{[^}]*$|^\\s*@(?:if|for|each|else-if|else).*\\{\\s*$",
    "decreaseIndentPattern": "^\\s*\\}",
    "indentNextLinePattern": "^\\s*@(?:if|for|each|else-if|else)\\b[^{]*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*//",
      "action": { "indent": "none", "appendText": "// " }
    },
    {
      "beforeText": "^\\s*/\\*\\*(?!/).*$",
      "action": { "indent": "none", "appendText": " * " }
    },
    {
      "beforeText": "^\\s*\\*(?!/).*$",
      "afterText": "^\\s*\\*/$",
      "action": { "indent": "none", "appendText": " * " }
    },
    {
      "beforeText": "^\\s*\\*/\\s*$",
      "action": { "indent": "none", "removeText": 1 }
    },
    {
      "beforeText": "\\{\\s*$",
      "afterText": "^\\s*\\}",
      "action": { "indent": "indentOutdent", "appendText": "  " }
    }
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|(@[a-zA-Z][a-zA-Z0-9-]*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}
